# =============================================================================
# Ports (see docker-compose.yml — only FRONTEND_HOST_PORT is published)
# =============================================================================
API_PORT=8000
API_BIND_HOST=0.0.0.0
API_BASE_URL=http://127.0.0.1:8000
FRONTEND_HOST_PORT=8000
FRONTEND_CONTAINER_PORT=3000

# Local dev (npm run dev on :3000)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
# Docker: docker-compose build uses http://api:${API_PORT} — do not set 127.0.0.1 for production image

# =============================================================================
# Providers & storage
# =============================================================================
ADATA_TOKEN=
ADATA_BASE_URL=https://api.adata.kz/api/company
ADATA_TIMEOUT_SECONDS=30
ADATA_POLL_ATTEMPTS=10
ADATA_POLL_DELAY_SECONDS=2

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Langfuse — LLM tracing (optional; reads LANGFUSE_* from env when set)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

LSEG_CLIENT_ID=
LSEG_CLIENT_SECRET=
LSEG_GROUP_ID=

USE_STUB_ON_API_FAILURE=true

DATABASE_URL=postgresql://akashicompliance:akashicompliance@127.0.0.1:5432/akashicompliance
SQLITE_PATH=data/compliance.db
PDF_DIR=generated-pdfs

REDIS_URL=redis://127.0.0.1:6379/0
TASK_QUEUE_ENABLED=true
TASK_RESULT_TTL_SECONDS=3600
TASKIQ_WORKERS=1
WORKER_HEARTBEAT_TTL_SECONDS=30
WORKER_HEARTBEAT_INTERVAL_SECONDS=10

GRAPH_PROBE_CONCURRENCY=3

AUTH_ENABLED=true
ADMIN_USERNAME=nurikw3
ADMIN_PASSWORD=change-me

# CORS_ORIGINS=https://ai.akashi.cloud
